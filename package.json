{
    "name": "sat-track",
    "version": "2.0.0",
    "description": "Real-time 3D satellite constellation tracker",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
        "lint": "eslint src/ tests/",
        "lint:fix": "eslint src/ tests/ --fix",
        "format": "prettier --write 'src/**/*.js' 'tests/**/*.js' '*.json' '*.md'",
        "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js' '*.json' '*.md'"
    },
    "dependencies": {
        "three": "^0.172.0",
        "satellite.js": "^4.0.0"
    },
    "devDependencies": {
        "vite": "^6.2.0",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "@jest/globals": "^29.7.0",
        "prettier": "^3.2.0"
    },
    "jest": {
        "transform": {},
        "testEnvironment": "node"
    },
    "license": "MIT"
}
