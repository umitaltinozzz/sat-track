{
    "env": {
        "browser": true,
        "es2021": true,
        "jest": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "globals": {},
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-console": "off",
        "eqeqeq": ["error", "always"],
        "no-var": "error",
        "prefer-const": "warn",
        "no-eval": "error",
        "no-implied-eval": "error"
    }
}
